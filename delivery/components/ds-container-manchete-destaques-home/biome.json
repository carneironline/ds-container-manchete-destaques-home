{
	"$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": false,
			"performance": {
				"recommended": true
			},
			"style": {
				"recommended": true
			},
			"complexity": {
				"recommended": true
			}
		}
	},
	"javascript": {
		"formatter": {
			"indentStyle": "space",
			"trailingCommas": "es5",
			"semicolons": "asNeeded",
			"arrowParentheses": "asNeeded",
			"lineWidth": 120
		}
	}
}
