{
    "name": "ds-container-manchete-destaques-home",
    "description": "Delivery Component: ds-container-manchete-destaques-home",
    "version": "1.0.0",
    "scripts": {
        "build": "pnpm build:client && pnpm build:server",
        "build:watch": "concurrently --kill-others \"pnpm build:client:watch\" \"pnpm build:server:watch\"",
        "build:client:watch": "webpack --mode production --config config/webpack.client.js --watch",
        "build:server:watch": "webpack --mode production --config config/webpack.server.js --watch",
        "build:client": "webpack --mode production --config config/webpack.client.js",
        "build:server": "webpack --mode production --config config/webpack.server.js",
        "lint": "biome lint ./src",
        "serve": "npx serve dist/ -p 3001",
        "start": "pnpm build && pnpm serve",
        "sandbox:watch": "concurrently --kill-others \"delivery-sandbox-js\" \"pnpm -r --parallel --stream run build:watch\"",
        "sandbox": "pnpm build && delivery-sandbox-js"
    },
    "delivery": {
        "metadata": {},
        "scope": "dsContainerMancheteDestaquesHome",
        "modules": {
            "./Component": "./src/Component",
            "./Raw": "./src/Raw"
        },
        "channels": {
            "desktop": {
                "module": "./Component"
            },
            "smart": {
                "alias": "desktop"
            },
            "raw": {
                "module": "./Raw"
            }
        },
        "criticalStylesheets": [
            "style"
        ],
        "type": "component",
        "author": "infoglobo",
        "functions": {},
        "renderVersions": [
            "delivery-react18-render"
        ]
    },
    "devDependencies": {
        "@babel/core": "7.24.6",
        "@babel/plugin-transform-class-properties": "^7.25.9",
        "@babel/plugin-transform-runtime": "7.24.6",
        "@babel/preset-env": "7.24.6",
        "@babel/preset-react": "7.24.6",
        "@babel/preset-typescript": "^7.28.5",
        "@biomejs/biome": "^1.7.3",
        "@module-federation/node": "2.2.6",
        "@types/react": "^18.2.0",
        "babel-loader": "9.2.1",
        "concurrently": "^9.1.2",
        "copy-webpack-plugin": "^13.0.0",
        "delivery-sandbox-js": "^1.1.0",
        "html-webpack-plugin": "5.6.0",
        "mini-css-extract-plugin": "^2.9.2",
        "pnpm": "^9.15.4",
        "sass": "^1.101.0",
        "sass-loader": "^17.0.0",
        "typescript": "^5.4.5",
        "webpack": "5.91.0",
        "webpack-cli": "4.10.0",
        "webpack-dev-server": "4.15.2",
        "webpack-merge": "5.10.0"
    },
    "dependencies": {
        "@babel/runtime": "^7.13.10",
        "@nodo-ds/react-ui": "0.1.0-alpha.8",
        "css-loader": "^7.1.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-helmet-async": "^2.0.5",
        "style-loader": "^4.0.0"
    }
}
